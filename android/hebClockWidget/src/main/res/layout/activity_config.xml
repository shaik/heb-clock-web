<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="שעון עברי — הגדרות"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <!-- Theme -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Theme"
            android:textColor="#AAAACC"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_theme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <RadioButton
                android:id="@+id/rb_dark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Dark"
                android:textColor="#FFFFFF"
                android:buttonTint="#AAAACC" />

            <RadioButton
                android:id="@+id/rb_light"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Light"
                android:textColor="#FFFFFF"
                android:buttonTint="#AAAACC" />

        </RadioGroup>

        <!-- Show suffix -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Time of day suffix"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="בבוקר / בערב / בלילה"
                    android:textColor="#AAAACC"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/sw_suffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#AAAACC"
                android:trackTint="#444466" />

        </LinearLayout>

        <!-- Suffix slot schedule label -->
        <TextView
            android:id="@+id/tv_suffix_slots_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suffix schedule"
            android:textColor="#AAAACC"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Suffix slot rows (populated programmatically) -->
        <LinearLayout
            android:id="@+id/suffix_slots_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp" />

        <!-- Show modifier -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fuzzy modifier"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="קצת לפני / קצת אחרי"
                    android:textColor="#AAAACC"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/sw_modifier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#AAAACC"
                android:trackTint="#444466" />

        </LinearLayout>

        <!-- Niqqud -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Niqqud (vowel marks)"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שְׁתֵּים עֶשְׂרֵה וְחֵצִי בַּלַּיְלָה"
                    android:textColor="#AAAACC"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/sw_niqqud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#AAAACC"
                android:trackTint="#444466" />

        </LinearLayout>

        <!-- Compact labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Compact prefix/suffix"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="smaller קצת לפני and בלילה"
                    android:textColor="#AAAACC"
                    android:textSize="13sp" />

            </LinearLayout>

            <Switch
                android:id="@+id/sw_compact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:thumbTint="#AAAACC"
                android:trackTint="#444466" />

        </LinearLayout>

        <!-- Font size -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Font size"
            android:textColor="#AAAACC"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_font_size"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="40dp">

            <RadioButton
                android:id="@+id/rb_small"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Small"
                android:textColor="#FFFFFF"
                android:buttonTint="#AAAACC" />

            <RadioButton
                android:id="@+id/rb_medium"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Medium"
                android:textColor="#FFFFFF"
                android:buttonTint="#AAAACC" />

            <RadioButton
                android:id="@+id/rb_large"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Large"
                android:textColor="#FFFFFF"
                android:buttonTint="#AAAACC" />

        </RadioGroup>

        <!-- Save -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3D3D6B" />

        <!-- Version -->
        <TextView
            android:id="@+id/tv_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="#555577"
            android:textSize="12sp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</ScrollView>
